[*]
end_of_line = lf
indent_style = space
insert_final_newline = false
trim_trailing_whitespace = true

[*.{py,json}]
indent_size = 4
insert_final_newline = true

[*.{html,htm,hta,js}]
indent_size = 2
insert_final_newline = true

[*.{bat,cmd,ps1,psm1,psd1}]
end_of_line = crlf
insert_final_newline = true
